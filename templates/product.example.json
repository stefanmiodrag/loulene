      }
    },
    "31cc5823-28d5-45a2-882e-37655bbc8c69": {
      "type": "section-accordion",
      "blocks": {
        "8fdcc3cc-5810-4bae-a88f-7d2ac651517c": {
          "type": "text",
          "settings": {
            "title": "",
            "heading_font_size": "heading-small",
            "text": "<p>Should you require guidance while selecting your size, please feel free to reach out to our customer support team. Keep in mind that the sizes displayed in our Size Charts are approximate. We encourage you to shop thoughtfully and consult our Size Chart for the most accurate fit.</p>"
          }
        }
