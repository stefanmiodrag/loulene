        },
        "accordion_Tpax6M": {
          "type": "accordion",
          "settings": {
            "style": "drawer",
            "show_description": false,
            "show_read_more": true,
            "default_open": false,
            "heading": "Fabric & Care",
            "heading_font_size": "body-small",
            "text": "<p>Made from carefully selected fabrics that balance comfort, durability, and elegance. To keep your piece looking its best, we recommend washing on a gentle cycle or by hand in cold water, then laying flat to dry. Avoid harsh detergents or high heat. Refer to the garment label for full care instructions.</p>",
            "text_font_size": "body-medium",
            "show_icon": false,
            "icon_name": "icon-award",
            "icon_size": 20,
            "icon_color": "",
            "padding_bottom": 0
          }
        },
        "accordion_VBxAXL": {
          "type": "accordion",
          "settings": {
